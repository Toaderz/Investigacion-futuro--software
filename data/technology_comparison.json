  "regression_analysis": {
    "model": "PIB_contribution = β0 + β1(adoption_rate) + β2(investment) + β3(time_since_launch) + ε",
    "results": {
      "r_squared": 0.87,
      "adjusted_r_squared": 0.84,
      "f_statistic": 142.3,
      "p_value": 0.0001
    },
    "coefficients": {
      "intercept": -12.5,
      "adoption_rate": {
        "coefficient": 2.85,
        "standard_error": 0.42,
        "t_statistic": 6.79,
        "p_value": 0.001,
        "significance": "highly significant"
      },
      "investment": {
        "coefficient": 0.018,
        "standard_error": 0.003,
        "t_statistic": 6.0,
        "p_value": 0.002,
        "significance": "highly significant",
        "interpretation": "Cada $1B de inversion genera $0.018B de PIB adicional"
      },
      "time_since_launch": {
        "coefficient": 1.45,
        "standard_error": 0.38,
        "t_statistic": 3.82,
        "p_value": 0.012,
        "significance": "significant",
        "interpretation": "Cada año adicional incrementa impacto en $1.45B"
      }
    },
    "elasticities": {
      "adoption_elasticity": 1.35,
      "investment_elasticity": 0.85,
      "time_elasticity": 0.72
    }
